{
  "name": "ifood-batch-crawler",
  "version": "1.0.0",
  "description": "Sequential batch crawler CLI with offline-testable iFood extraction",
  "type": "module",
  "private": true,
  "packageManager": "npm@10.8.2",
  "bin": {
    "ifood-crawler": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests vitest.config.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "audit": "npm audit --omit=dev",
    "docker:build": "docker build --pull -t crawling-neogrid:local .",
    "docker:smoke": "docker run --rm crawling-neogrid:local --help && docker run --rm crawling-neogrid:local --version",
    "verify:output": "tsx scripts/verify-output.ts",
    "verify:delivery": "node scripts/verify-delivery.mjs",
    "benchmark:offline": "node scripts/benchmark-offline.mjs",
    "evidence:quality": "node scripts/generate-quality-evidence.mjs",
    "finalize:delivery": "node scripts/finalize-delivery.mjs",
    "record:execution": "node scripts/record-execution-evidence.mjs",
    "package:delivery": "node scripts/package-delivery.mjs"
  },
  "keywords": [
    "crawler",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "pino": "^9.6.0",
    "playwright": "^1.61.1",
    "zod": "^3.24.1"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.23",
    "@vitest/coverage-v8": "^4.1.10",
    "archiver": "^8.0.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.10"
  }
}
