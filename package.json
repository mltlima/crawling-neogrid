{
  "name": "ifood-batch-crawler",
  "version": "1.0.0",
  "description": "Offline input-validation CLI for the Neogrid batch crawler",
  "type": "module",
  "private": true,
  "bin": {
    "ifood-crawler": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests vitest.config.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "keywords": [
    "crawler",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "pino": "^9.6.0",
    "playwright": "^1.61.1",
    "zod": "^3.24.1"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.23",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.10"
  }
}
